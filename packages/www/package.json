{
    "name": "party",
    "private": true,
    "sideEffects": false,
    "type": "module",
    "scripts": {
        "dev": "vp exec alchemy dev alchemy.run.ts",
        "dev:vite": "vite dev",
        "dev:party": "node --import tsx scripts/dev-party.ts",
        "build": "vite build && tsc --noEmit",
        "typecheck": "tsc --noEmit",
        "preview": "vite preview",
        "deploy": "NODE_OPTIONS='--conditions=import' vp exec alchemy deploy alchemy.run.ts --yes --adopt",
        "destroy": "vp exec alchemy destroy alchemy.run.ts",
        "cf-typegen": "wrangler types",
        "postinstall": "npm run cf-typegen",
        "test:unit": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "node --import tsx scripts/run-e2e.ts",
        "test:browser:deps": "playwright install chromium",
        "test:all": "npm run test:unit && npm run test:e2e -- all && npm run test:e2e -- --browser all",
        "trace": "node --import tsx scripts/open-trace.ts",
        "report": "playwright show-report playwright-report"
    },
    "dependencies": {
        "@party/effect-utils": "workspace:*",
        "@tanstack/solid-router": "^1.141.8",
        "@tanstack/solid-router-devtools": "^1.141.8",
        "@tanstack/solid-start": "^1.142.5",
        "animejs": "^4.2.2",
        "effect": "4.0.0-beta.70",
        "luxon": "^3.7.2",
        "nanoid": "^5.1.6",
        "remeda": "^2.32.2",
        "solid-js": "^1.9.10"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.32.3",
        "@cloudflare/vitest-pool-workers": "^0.14.7",
        "@effect/platform-node": "4.0.0-beta.70",
        "@playwright/test": "^1.60.0",
        "@solidjs/testing-library": "^0.8.10",
        "@tailwindcss/vite": "^4.1.18",
        "@testing-library/jest-dom": "^6.9.1",
        "@types/luxon": "^3.7.1",
        "@types/node": "^22.5.4",
        "alchemy": "2.0.0-beta.43",
        "fast-check": "^4.8.0",
        "happy-dom": "^20.9.0",
        "playwright": "^1.60.0",
        "tailwindcss": "^4.1.18",
        "tsx": "^4.21.0",
        "typescript": "^5.7.2",
        "vite": "^8.0.7",
        "vite-plugin-solid": "^2.11.10",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^4.1.4",
        "wrangler": "^4.81.1"
    }
}
