{
    "name": "tanstack-solid-start-example-basic-cloudflare",
    "private": true,
    "sideEffects": false,
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build && tsc --noEmit",
        "typecheck": "tsc --noEmit",
        "preview": "vite preview",
        "deploy": "npm run build && wrangler deploy",
        "cf-typegen": "wrangler types",
        "postinstall": "npm run cf-typegen",
        "test:unit": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:browser:deps": "playwright install chromium",
        "test:browser:yahtzee": "node --import tsx e2e/yahtzee-seeded.spec.ts",
        "test:browser:yahtzee:update": "YAHTZEE_UPDATE_SCREENSHOTS=1 node --import tsx e2e/yahtzee-seeded.spec.ts",
        "test:all": "npm run test:unit && npm run test:browser:yahtzee"
    },
    "dependencies": {
        "@tanstack/solid-router": "^1.141.8",
        "@tanstack/solid-router-devtools": "^1.141.8",
        "@tanstack/solid-start": "^1.142.5",
        "animejs": "^4.2.2",
        "effect": "4.0.0-beta.50",
        "luxon": "^3.7.2",
        "nanoid": "^5.1.6",
        "remeda": "^2.32.2",
        "solid-js": "^1.9.10",
        "zod": "^4.2.1"
    },
    "devDependencies": {
        "@browserbasehq/stagehand": "^3.2.1",
        "@cloudflare/vite-plugin": "^1.13.7",
        "@solidjs/testing-library": "^0.8.10",
        "@tailwindcss/vite": "^4.1.18",
        "@testing-library/jest-dom": "^6.9.1",
        "@types/luxon": "^3.7.1",
        "@types/node": "^22.5.4",
        "happy-dom": "^20.9.0",
        "playwright": "^1.59.1",
        "tailwindcss": "^4.1.18",
        "tsx": "^4.21.0",
        "typescript": "^5.7.2",
        "vite": "^7.1.7",
        "vite-plugin-solid": "^2.11.10",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^4.1.4",
        "wrangler": "^4.81.1"
    }
}
